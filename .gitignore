# Quality session data (keep directory structure)
.claude/quality/sessions/*
!.claude/quality/sessions/.gitkeep

# Lessons (user-specific, accumulates over time — starter template ships instead)
.claude/quality/ecosystem/lessons.json

# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# Python cache
__pycache__/
*.pyc

# Temporary files
*.tmp
*.temp

# Local Claude Code settings (contains machine-specific paths)
.claude/settings.local.json

# Update script reference file (per-install, not shared)
.claude/bcos-claude-reference.md

# Hook state (session-specific, machine-local)
.claude/hook_state/*
!.claude/hook_state/.gitkeep

# Auto-generated wake-up context (regenerated per user)
docs/.wake-up-context.md

# Auto-generated document index (regenerated per user via build_document_index.py)
docs/document-index.md

# Schedule dispatcher runtime artifacts (v1.2+)
# The template ships (schedule-config.template.json); the live config does not.
.claude/quality/schedule-config.json
# Migration trigger flag — written by update.py when v1.x tasks detected, deleted by schedule-migrate on success
.claude/MIGRATION-NEEDED.md
# Daily digest is runtime output, overwritten each morning
docs/_inbox/daily-digest.md

# Private publish script (repo-specific config)
.claude/scripts/publish.sh

# Private strategy docs (not for public repo)
.private/

# Syncthing marker folder (per-machine sync setup, not repo content)
.stfolder/
