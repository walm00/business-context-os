        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/bin/python3\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_commit_context_check.py\"",
