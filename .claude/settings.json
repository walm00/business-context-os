{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob",
      "Grep",
      "Bash(python .claude/scripts/append_diary.py:*)",
      "Bash(python .claude/scripts/build_document_index.py:*)",
      "Bash(python .claude/scripts/generate_wakeup_context.py:*)",
      "Bash(python .claude/scripts/analyze_crossrefs.py:*)",
      "Bash(python .claude/scripts/analyze_integration.py:*)",
      "Bash(python .claude/scripts/prune_sessions.py:*)",
      "Bash(python .claude/scripts/prune_diary.py:*)",
      "Bash(python3 .claude/scripts/append_diary.py:*)",
      "Bash(python3 .claude/scripts/build_document_index.py:*)",
      "Bash(python3 .claude/scripts/generate_wakeup_context.py:*)",
      "Bash(python3 .claude/scripts/analyze_crossrefs.py:*)",
      "Bash(python3 .claude/scripts/analyze_integration.py:*)",
      "Bash(python3 .claude/scripts/prune_sessions.py:*)",
      "Bash(python3 .claude/scripts/prune_diary.py:*)",
      "Read(.claude/hook_state/**)",
      "Edit(.claude/hook_state/**)",
      "Write(.claude/hook_state/**)",
      "Read(.claude/quality/**)",
      "Edit(.claude/quality/ecosystem/**)",
      "Write(.claude/quality/ecosystem/**)",
      "Edit(.claude/quality/schedule-config.json)",
      "Edit(docs/.wake-up-context.md)",
      "Write(docs/.wake-up-context.md)",
      "Edit(docs/.session-diary.md)",
      "Write(docs/.session-diary.md)",
      "Edit(docs/.onboarding-checklist.md)",
      "Write(docs/.onboarding-checklist.md)",
      "Edit(docs/document-index.md)",
      "Write(docs/document-index.md)",
      "Edit(docs/_inbox/**)",
      "Write(docs/_inbox/**)",
      "Skill(schedule-dispatcher)",
      "Skill(schedule-dispatcher:*)",
      "Skill(context-audit)",
      "Skill(context-audit:*)",
      "Skill(daydream)",
      "Skill(daydream:*)",
      "Skill(doc-lint)",
      "Skill(doc-lint:*)",
      "Skill(ecosystem-manager)",
      "Skill(ecosystem-manager:*)",
      "Skill(lessons-consolidate)",
      "Skill(lessons-consolidate:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto_save_session.sh\"",
            "timeout": 10,
            "statusMessage": "Checking session capture checkpoint..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/precompact_save.sh\"",
            "timeout": 10,
            "statusMessage": "Emergency save before context compaction..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_edit_frontmatter_check.py\"",
            "timeout": 10,
            "statusMessage": "Checking frontmatter compliance..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_edit_frontmatter_check.py\"",
            "timeout": 10,
            "statusMessage": "Checking frontmatter compliance..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_commit_context_check.py\"",
            "timeout": 15,
            "statusMessage": "Checking commit for context capture opportunities..."
          }
        ]
      }
    ]
  }
}
